          "name": "New Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json(); \r",
                  "pm.collectionVariables.set(\"authToken\", json.token); \r",
                  "pm.test(\"Login returns 200\", function() { \r",
                  "    pm.response.to.have.status(200); \r",
                  "}); \r",
                  "pm.test(\"Response contains token\", function() { \r",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty; \r",
